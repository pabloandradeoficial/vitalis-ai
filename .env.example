# ============================================================
# Vitalis AI — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# ------------------------------------------------------------
# Banco de Dados (Vercel Postgres ou Neon)
# ------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vitalis?sslmode=require"

# Para Prisma com connection pooling (Vercel Postgres usa isso)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/vitalis?sslmode=require"

# ------------------------------------------------------------
# Clerk — Autenticação
# Crie uma conta em https://clerk.com e um novo projeto
# ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx"

# Rotas de redirecionamento do Clerk (não alterar)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
# URL base do seu deploy (sem barra no final)
NEXT_PUBLIC_APP_URL="https://vitalis-ai.vercel.app"

# Em desenvolvimento:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
